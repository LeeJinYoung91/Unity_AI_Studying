# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/AI_JinYoung/[Ll]ibrary/
/AI_JinYoung/[Tt]emp/
/AI_JinYoung/[Oo]bj/
/AI_JinYoung/[Bb]uild/
/AI_JinYoung/[Bb]uilds/
/AI_JinYoung/[Ll]ogs/
/AI_JinYoung/[Uu]ser[Ss]ettings/
/[Bb]uild/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/AI_JinYoung/[Mm]emoryCaptures/

# Recordings can get excessive in size
/AI_JinYoung/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/AI_JinYoung/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
/AI_JinYoung/.vs/

# Gradle cache directory
/AI_JinYoung/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
/AI_JinYoung/.consulo/
/AI_JinYoung/*.csproj
/AI_JinYoung/*.unityproj
/AI_JinYoung/*.sln
/AI_JinYoung/*.suo
/AI_JinYoung/*.tmp
/AI_JinYoung/*.user
/AI_JinYoung/*.userprefs
/AI_JinYoung/*.pidb
/AI_JinYoung/*.booproj
/AI_JinYoung/*.svd
/AI_JinYoung/*.pdb
/AI_JinYoung/*.mdb
/AI_JinYoung/*.opendb
/AI_JinYoung/*.VC.db

# Unity3D generated meta files
/AI_JinYoung/*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
/AI_JinYoung/sysinfo.txt

# Builds
/AI_JinYoung/*.apk
/AI_JinYoung/*.aab
/AI_JinYoung/*.unitypackage
/AI_JinYoung/*.app
/AI_JinYoung/.utmp/

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/AI_JinYoung/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/AI_JinYoung/[Aa]ssets/[Ss]treamingAssets/aa.meta
/AI_JinYoung/[Aa]ssets/[Ss]treamingAssets/aa/*
/AI_JinYoung/[sS]erverData/*
